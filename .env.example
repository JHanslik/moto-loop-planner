# ---------------------------------------------------------------------------
# Moto Loop Planner — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# ---------------------------------------------------------------------------

# --- Supabase (OPTIONAL) ----------------------------------------------------
# Leave these empty to run the app in "planner-only" mode (route generation,
# map and GPS export all work without an account). Fill them in to enable
# authentication, saved rides and the community feed.
# Get them from: Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Routing engine (OPTIONAL) ---------------------------------------------
# Defaults to the public OSRM demo server. For production / heavy use, point
# this at your own OSRM instance or a GraphHopper endpoint.
# OSRM_BASE_URL=https://router.project-osrm.org
